{
  "name": "turtl-green-theme",
  "version": "1.0.0",
  "description": "Turtl Green Theme",
  "scripts": {
    "start": "hs-cms-dev-server . --generateFieldsTypes",
    "start:storybook": "npm run tailwind:build && hs-cms-dev-server . --storybook",
    "auth": "hs account auth",
    "deploy": "npm run tailwind:build && npx --yes --package @hubspot/cli@latest hs project upload",
    "tailwind:build": "npx @tailwindcss/cli -i ./styles/tailwind.css -o ./assets/tailwind.css",
    "tailwind:watch": "npx @tailwindcss/cli -i ./styles/tailwind.css -o ./assets/tailwind.css --watch"
  },
  "type": "module",
  "keywords": [],
  "dependencies": {
    "@hubspot/cms-components": "latest",
    "react": "^18",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@hubspot/cms-dev-server": "latest",
    "@tailwindcss/cli": "^4",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
